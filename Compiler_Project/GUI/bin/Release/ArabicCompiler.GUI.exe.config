<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5.2" />
    </startup>
    <appSettings>
        <add key="CompilerDllPath" value="CompilerCore.dll" />
        <add key="DefaultSourceFile" value="program.txt" />
        <add key="DefaultMipsFile" value="program.s" />
        <add key="EnableSyntaxHighlighting" value="true" />
        <add key="ShowLineNumbers" value="true" />
        <add key="RightToLeftLayout" value="true" />
    </appSettings>
</configuration>
