برنامج
[
  ثوابت
    ثابت_أقصى_عدد صحيح = 1000 ؛
    ثابت_رسالة_ترحيب نص = "مرحبا بك في البرنامج" ؛
    ثابت_نسبة_الضريبة حقيقي = 0.15 ؛
  
  أنواع
    سجل منتج
      كود صحيح ؛
      اسم نص ؛
      سعر حقيقي ؛
      كمية صحيح ؛
      متوفر منطقي ؛
    ؛
    
    سجل طلب
      رقم_الطلب صحيح ؛
      تاريخ نص ؛
      منتجات منتج [10] ؛
      إجمالي_السعر حقيقي ؛
      مدفوع منطقي ؛
    ؛
  
  متغيرات
    قائمة_المنتجات منتج [50] ؛
    قائمة_الطلبات طلب [100] ؛
    عداد_المنتجات صحيح ؛
    عداد_الطلبات صحيح ؛
    إجمالي_المبيعات حقيقي ؛
  
  إجراءات
    إجراء إضافة_منتج (كود صحيح، اسم نص، سعر حقيقي، كمية صحيح) ؛
      قائمة_المنتجات [عداد_المنتجات].كود = كود ؛
      قائمة_المنتجات [عداد_المنتجات].اسم = اسم ؛
      قائمة_المنتجات [عداد_المنتجات].سعر = سعر ؛
      قائمة_المنتجات [عداد_المنتجات].كمية = كمية ؛
      قائمة_المنتجات [عداد_المنتجات].متوفر = صحيح ؛
      عداد_المنتجات = عداد_المنتجات + 1 ؛
    ؛
    
    إجراء إنشاء_طلب (رقم_طلب صحيح) ؛
      قائمة_الطلبات [عداد_الطلبات].رقم_الطلب = رقم_طلب ؛
      قائمة_الطلبات [عداد_الطلبات].تاريخ = "اليوم" ؛
      قائمة_الطلبات [عداد_الطلبات].إجمالي_السعر = 0.0 ؛
      قائمة_الطلبات [عداد_الطلبات].مدفوع = خطأ ؛
      عداد_الطلبات = عداد_الطلبات + 1 ؛
    ؛
    
    إجراء حساب_إجمالي_السعر (رقم_طلب صحيح) ؛
      عداد صحيح ؛
      إجمالي حقيقي ؛
      
      عداد = 0 ؛
      إجمالي = 0.0 ؛
      
      طالما عداد < 10
        إذا قائمة_الطلبات [رقم_طلب].منتجات [عداد].كمية > 0
          إجمالي = إجمالي + (قائمة_الطلبات [رقم_طلب].منتجات [عداد].سعر * قائمة_الطلبات [رقم_طلب].منتجات [عداد].كمية) ؛
        ؛
        عداد = عداد + 1 ؛
      ؛
      
      قائمة_الطلبات [رقم_طلب].إجمالي_السعر = إجمالي ؛
    ؛
    
    إجراء طباعة_تقرير () ؛
      عداد صحيح ؛
      
      اطبع "=== تقرير المبيعات ===" ؛
      اطبع "إجمالي المبيعات: " ؛
      اطبع إجمالي_المبيعات ؛
      اطبع "عدد المنتجات: " ؛
      اطبع عداد_المنتجات ؛
      اطبع "عدد الطلبات: " ؛
      اطبع عداد_الطلبات ؛
      
      عداد = 0 ؛
      طالما عداد < عداد_المنتجات
        اطبع "المنتج " ؛
        اطبع عداد ؛
        اطبع ": " ؛
        اطبع قائمة_المنتجات [عداد].اسم ؛
        اطبع " - السعر: " ؛
        اطبع قائمة_المنتجات [عداد].سعر ؛
        اطبع " - الكمية: " ؛
        اطبع قائمة_المنتجات [عداد].كمية ؛
        عداد = عداد + 1 ؛
      ؛
    ؛
]
:
  # تهيئة المتغيرات
  عداد_المنتجات = 0 ؛
  عداد_الطلبات = 0 ؛
  إجمالي_المبيعات = 0.0 ؛
  
  # إضافة منتجات
  استدعاء إضافة_منتج (1، "لابتوب"، 1500.0، 10) ؛
  استدعاء إضافة_منتج (2، "هاتف ذكي"، 800.0، 20) ؛
  استدعاء إضافة_منتج (3، "سماعات"، 100.0، 50) ؛
  استدعاء إضافة_منتج (4، "قارئ إلكتروني"، 200.0، 15) ؛
  
  # إنشاء طلبات
  استدعاء إنشاء_طلب (1) ؛
  استدعاء إنشاء_طلب (2) ؛
  
  # إضافة منتجات للطلبات
  قائمة_الطلبات [0].منتجات [0] = قائمة_المنتجات [0] ؛
  قائمة_الطلبات [0].منتجات [0].كمية = 2 ؛
  
  قائمة_الطلبات [1].منتجات [0] = قائمة_المنتجات [1] ؛
  قائمة_الطلبات [1].منتجات [0].كمية = 1 ؛
  قائمة_الطلبات [1].منتجات [1] = قائمة_المنتجات [2] ؛
  قائمة_الطلبات [1].منتجات [1].كمية = 3 ؛
  
  # حساب الإجماليات
  استدعاء حساب_إجمالي_السعر (0) ؛
  استدعاء حساب_إجمالي_السعر (1) ؛
  
  # حساب إجمالي المبيعات
  عداد = 0 ؛
  طالما عداد < عداد_الطلبات
    إجمالي_المبيعات = إجمالي_المبيعات + قائمة_الطلبات [عداد].إجمالي_السعر ؛
    عداد = عداد + 1 ؛
  ؛
  
  # طباعة التقرير
  استدعاء طباعة_تقرير () ؛
  
  # طباعة رسالة الختام
  اطبع "تم تنفيذ البرنامج بنجاح!" ؛
؛

