برنامج
[
  متغيرات
    متغير صحيح ؛
    متغير2 حقيقي ؛
    متغير3 نص ؛
]
:
  متغير = 42 ؛
  متغير2 = 3.14 ؛
  متغير3 = "مرحبا" ؛
  
  # أخطاء دلالية
  متغير = متغير2 ؛  # تعيين حقيقي إلى صحيح
  متغير2 = متغير3 ؛  # تعيين نص إلى حقيقي
  متغير3 = متغير ؛  # تعيين صحيح إلى نص
  
  # استخدام متغير غير معرف
  متغير4 = 10 ؛
  
  # عملية غير صحيحة
  متغير = متغير + متغير3 ؛  # جمع صحيح مع نص
  
  # استدعاء إجراء غير موجود
  استدعاء إجراء_غير_موجود () ؛
  
  اطبع متغير ؛
  اطبع متغير2 ؛
  اطبع متغير3 ؛
؛

