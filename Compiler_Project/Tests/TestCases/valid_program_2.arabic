برنامج
[
  متغيرات
    عداد صحيح ؛
    مجموع صحيح ؛
    أقصى_قيمة صحيح ؛
]
:
  عداد = 1 ؛
  مجموع = 0 ؛
  أقصى_قيمة = 10 ؛
  
  طالما عداد <= أقصى_قيمة
    مجموع = مجموع + عداد ؛
    عداد = عداد + 1 ؛
  ؛
  
  اطبع "المجموع: " ؛
  اطبع مجموع ؛
  
  إذا مجموع > 50
    اطبع "المجموع كبير" ؛
  وإلا إذا مجموع > 25
    اطبع "المجموع متوسط" ؛
  وإلا
    اطبع "المجموع صغير" ؛
  ؛
  
  كرر 5 مرات
    اطبع "تكرار" ؛
  ؛
؛

