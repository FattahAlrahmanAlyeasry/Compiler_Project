برنامج
[
  متغيرات
    متغير صحيح ؛
    متغير2 حقيقي ؛
]
:
  متغير = ؛  # تعبير مفقود
  متغير2 = 3.14 ؛
  
  إذا متغير > 10  # شرط بدون إغلاق
    اطبع "كبير" ؛
  
  طالما متغير < 20  # حلقة بدون إغلاق
    متغير = متغير + 1 ؛
  
  اطبع متغير ؛
  اطبع متغير2 ؛
  
  ؛  # فاصلة منقوطة زائدة
؛

