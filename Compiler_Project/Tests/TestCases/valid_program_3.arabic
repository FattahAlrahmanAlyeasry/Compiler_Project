برنامج
[
  أنواع
    سجل طالب
      اسم نص ؛
      عمر صحيح ؛
      درجة حقيقي ؛
      نجح منطقي ؛
    ؛
  متغيرات
    أرقام صحيح [10] ؛
    طلاب طالب [5] ؛
    عداد صحيح ؛
    مجموع_الدرجات حقيقي ؛
]
:
  عداد = 0 ؛
  مجموع_الدرجات = 0.0 ؛
  
  طالما عداد < 10
    أرقام [عداد] = عداد * 2 ؛
    عداد = عداد + 1 ؛
  ؛
  
  طلاب [0].اسم = "أحمد" ؛
  طلاب [0].عمر = 20 ؛
  طلاب [0].درجة = 95.5 ؛
  طلاب [0].نجح = صحيح ؛
  
  طلاب [1].اسم = "فاطمة" ؛
  طلاب [1].عمر = 19 ؛
  طلاب [1].درجة = 88.0 ؛
  طلاب [1].نجح = صحيح ؛
  
  عداد = 0 ؛
  طالما عداد < 5
    إذا طلاب [عداد].نجح
      مجموع_الدرجات = مجموع_الدرجات + طلاب [عداد].درجة ؛
    ؛
    عداد = عداد + 1 ؛
  ؛
  
  اطبع "متوسط الدرجات: " ؛
  اطبع مجموع_الدرجات / 5 ؛
  
  اطبع "أرقام: " ؛
  عداد = 0 ؛
  طالما عداد < 10
    اطبع أرقام [عداد] ؛
    اطبع " " ؛
    عداد = عداد + 1 ؛
  ؛
؛

